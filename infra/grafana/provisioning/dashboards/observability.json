{
  "title": "Observability Demo",
  "uid": "observability-demo",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "RPS — Requests per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(api_total_seconds_count{application=\"observability-demo\"}[1m])",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latency p50 / p95 — api.total",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(api_total_seconds_bucket{application=\"observability-demo\"}[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(api_total_seconds_bucket{application=\"observability-demo\"}[1m])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 3,
      "title": "Errors — 5xx per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_server_requests_seconds_count{application=\"observability-demo\",status=~\"5..\"}[1m])",
          "legendFormat": "5xx errors/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Traces — Search in Tempo",
      "type": "traces",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{resource.service.name=\"observability-demo\"}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Latency p95 — все этапы",
      "description": "p95 latency для каждого этапа: первый API, второй API, вычисления, отправка результата",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(api_total_seconds_bucket{application=\"observability-demo\"}[1m])) by (le))",
          "legendFormat": "api.total p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(first_api_call_seconds_bucket{application=\"observability-demo\"}[1m])) by (le))",
          "legendFormat": "first.api.call p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(second_api_call_seconds_bucket{application=\"observability-demo\"}[1m])) by (le))",
          "legendFormat": "second.api.call p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(calculation_seconds_bucket{application=\"observability-demo\"}[1m])) by (le))",
          "legendFormat": "calculation p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(send_result_seconds_bucket{application=\"observability-demo\"}[1m])) by (le))",
          "legendFormat": "send.result p95"
        }
      ]
    },
    {
      "id": 6,
      "title": "Среднее время этапов (last 1m)",
      "description": "Среднее время выполнения каждого этапа за последнюю минуту",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(api_total_seconds_sum{application=\"observability-demo\"}[1m]) / rate(api_total_seconds_count{application=\"observability-demo\"}[1m])",
          "legendFormat": "api.total"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(first_api_call_seconds_sum{application=\"observability-demo\"}[1m]) / rate(first_api_call_seconds_count{application=\"observability-demo\"}[1m])",
          "legendFormat": "first.api.call"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(second_api_call_seconds_sum{application=\"observability-demo\"}[1m]) / rate(second_api_call_seconds_count{application=\"observability-demo\"}[1m])",
          "legendFormat": "second.api.call"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(calculation_seconds_sum{application=\"observability-demo\"}[1m]) / rate(calculation_seconds_count{application=\"observability-demo\"}[1m])",
          "legendFormat": "calculation"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(send_result_seconds_sum{application=\"observability-demo\"}[1m]) / rate(send_result_seconds_count{application=\"observability-demo\"}[1m])",
          "legendFormat": "send.result"
        }
      ]
    }
  ]
}
